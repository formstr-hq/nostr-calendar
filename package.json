{
  "name": "nostr-calendar",
  "version": "2.0.2",
  "type": "module",
  "repository": {
    "url": "https://github.com/formstr-hq/nostr-calendar"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild": "pnpm lint && pnpm typecheck",
    "lint": "eslint . --quiet",
    "preview": "vite preview",
    "simulate-android": "pnpm build && pnpm cap run android",
    "release-android": "./scripts/build-release.sh",
    "create-release": "./scripts/create-release.sh",
    "simulate-ios": "pnpm cap run ios",
    "build-ios": "pnpm cap build ios",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test:e2e": "playwright test --config e2e/web/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/web/playwright.config.ts --ui",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:native": "bash e2e/native/run.sh",
    "test:e2e:native:quick": "bash e2e/native/run.sh --skip-build"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/preferences": "^8.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.3.0",
    "@formstr/local-relay": "^0.4.2",
    "@formstr/sdk": "^0.2.7",
    "@formstr/signer": "^0.2.2",
    "@khadarvsk/capacitor-secure-storage": "0.0.3",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@mui/x-date-pickers": "^8.26.0",
    "@noble/hashes": "^2.0.0",
    "@voiceflow/normal-store": "^2.4.1",
    "bech32": "^2.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "framer-motion": "^12.29.2",
    "nostr-signer-capacitor-plugin": "^0.0.5",
    "nostr-tools": "^2.15.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.3",
    "react-intl": "^7.1.11",
    "react-markdown": "^10.1.0",
    "react-router": "^7.11.0",
    "react-select": "^5.10.2",
    "remark-gfm": "^4.0.1",
    "rrule": "^2.8.1",
    "tsx": "^4.22.4",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "workbox-window": "^7.4.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.6.0",
    "dotenv": "^16.0.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "nostr-mock-relay": "^0.1.1",
    "prettier": "3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
